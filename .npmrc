# Expo / React Native need a hoisted node_modules layout — pnpm's default
# symlinked store breaks Metro resolution. Do not remove these.
node-linker=hoisted
shamefully-hoist=true
strict-peer-dependencies=false

# NativeWind's babel rewrites JSX to import from react-native-css-interop directly;
# Metro must be able to resolve it from the app scope.
public-hoist-pattern[]=*react-native-css-interop*
public-hoist-pattern[]=*nativewind*
